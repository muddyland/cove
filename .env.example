# Port Cove listens on (HTTP / local entrypoint)
COVE_HTTP_PORT=80

# Timezone for workspace containers
TZ=UTC

# Whether session cookies are marked Secure (HTTPS-only).
# Keep false for local HTTP (localhost) so cookies work. SECURITY: a false value
# means the session cookie travels in cleartext and can be sniffed on the network,
# so only use it on localhost. For any networked/public deployment, serve over
# HTTPS (docker-compose.prod.yml, which sets this true) and set it to true here.
COVE_COOKIE_SECURE=false

# Persistent storage root for workspace home directories.
# Layout: {COVE_STORAGE_PATH}/{username}/workspace-{name}/
# This MUST be an absolute path that is identical on the host and inside the
# cove container (it is bind-mounted at the same path), so the bind mounts the
# backend creates for workspace containers resolve to the same directory the
# file browser reads. Defaults to /var/lib/cove/workspaces.
# COVE_STORAGE_PATH=/var/lib/cove/workspaces

# --- Production HTTPS (used with docker-compose.prod.yml) -------------------
# Public hostname and Let's Encrypt account email. Required when deploying with:
#   docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d
# COVE_DOMAIN=cove.example.com
# COVE_ACME_EMAIL=you@example.com

# --- Per-workspace subdomain isolation (optional) --------------------------
# When set, each workspace streams at {public_id}.{COVE_WORKSPACE_DOMAIN} — its
# own origin, so the workspace iframe cannot read the SPA's token. Unset = the
# default subpath routing (/workspace/{id}/). Requires a wildcard DNS record and
# a wildcard TLS cert (use docker-compose.dns.yml).
# The SPA session cookie is host-only and is NOT sent to workspace origins;
# streams authenticate with a separate, per-workspace stream token, so no shared
# cookie Domain is needed (or wanted).
# COVE_WORKSPACE_DOMAIN=cove.example.com

# --- ACME DNS-01 challenge (optional, add docker-compose.dns.yml) -----------
# Use DNS-01 instead of TLS-ALPN (needed behind a closed port 80/443 or for
# wildcard certs). Deploy with the extra override:
#   docker compose -f docker-compose.yml -f docker-compose.prod.yml \
#                  -f docker-compose.dns.yml up -d
# COVE_ACME_DNS_PROVIDER=cloudflare           # Traefik provider code
# COVE_ACME_DNS_RESOLVERS=1.1.1.1:53,8.8.8.8:53
# Provider credentials (example: Cloudflare scoped token) — names depend on
# your provider; Traefik reads them straight from the environment:
# CF_DNS_API_TOKEN=your-cloudflare-token

# --- OIDC / Authentik (optional — leave blank to use local auth only) ------
# COVE_OIDC_ISSUER=https://auth.example.com/application/o/cove/
# COVE_OIDC_CLIENT_ID=
# COVE_OIDC_CLIENT_SECRET=
# COVE_OIDC_ADMIN_GROUP=cove-admins
# COVE_OIDC_PROVIDER_NAME=Authentik
# Disable local username/password login + setup entirely (SSO only). Only takes
# effect when OIDC is configured, so a broken OIDC config can't lock you out —
# set back to false on the server to restore the local login form.
# COVE_OIDC_ONLY=false

# --- DB encryption at rest (optional) --------------------------------------
# COVE_DB_ENCRYPTION_KEY=

# README/docs assets — never part of the runtime image.
screenshots/

# VCS + CI metadata
.git/
.gitignore
.gitlab-ci.yml

# Local runtime state (DB, workspace storage, staged scripts/keys)
data/

# Dependencies / build output regenerated inside the image
